---
---
<div id="chat-console" class="bg-[#121418] border border-[#1c1f26] rounded-md flex flex-col h-full shadow-2xl overflow-hidden">
  
  <div id="pillars-container" class="bg-[#0b0c0e] border-b border-[#1c1f26] px-4 py-3 hidden">
    <span class="text-[9px] uppercase font-bold font-mono tracking-widest text-slate-500 block mb-2">TARGET SUBSURFACE SECTOR INTAKES:</span>
    <div id="pills-wrapper" class="flex flex-wrap gap-1.5"></div>
  </div>

  <div id="chat-arena" class="flex-1 p-5 overflow-y-auto space-y-5 bg-gradient-to-b from-[#0b0c0e]/20 to-transparent text-sm">
    <div class="max-w-xl border border-[#1c1f26] bg-[#0b0c0e]/60 rounded-md p-4 text-slate-400 font-mono space-y-1 text-xs">
      <p class="text-slate-200 font-bold">SYSTEM CORE INITIALIZED // INSTANCE RUNNING</p>
      <p class="text-slate-500">Provide a structured contract to isolate RAG segments, or run global lookups directly below.</p>
    </div>
  </div>

  <form id="chat-form" class="border-t border-[#1c1f26] p-4 bg-[#0b0c0e]/50 flex items-center gap-3 shrink-0">
    <input type="text" id="user-input" placeholder="Query contract parameters or assert regulatory thresholds..." autocomplete="off" class="flex-1 bg-[#0b0c0e] border border-[#1c1f26] rounded px-4 py-3.5 text-base text-slate-200 font-mono placeholder-slate-600 focus:outline-none focus:border-[#424b5d] transition-all" />
    <button type="submit" class="bg-[#84a98c] hover:bg-[#9dc1a3] text-slate-950 text-xs font-bold font-mono px-6 py-3.5 rounded transition-all uppercase tracking-widest shadow-md hover:shadow-[#84a98c]/10 cursor-pointer">
      EXECUTE
    </button>
  </form>
</div>

<script>
  let chatHistory: Array<{role: string, content: string}> = [];
  const chatArena = document.getElementById('chat-arena');
  const chatForm = document.getElementById('chat-form');
  const userInput = document.getElementById('user-input') as HTMLInputElement;
  const pillarsContainer = document.getElementById('pillars-container');
  const pillsWrapper = document.getElementById('pills-wrapper');

  window.addEventListener('document-processed', (e: any) => {
    pillarsContainer?.classList.remove('hidden');
    pillsWrapper!.innerHTML = '';
    
    e.detail.sections.forEach((section: string) => {
      const pill = document.createElement('button');
      pill.className = "px-2.5 py-1 text-[10px] font-mono rounded bg-[#121418] border border-[#1c1f26] text-slate-400 hover:text-slate-200 hover:border-slate-500 transition-colors cursor-pointer";
      pill.innerText = section.toUpperCase();
      pill.onclick = () => {
        userInput.value = `Audit core structures for segment: [${section}] // Target: `;
        userInput.focus();
      };
      pillsWrapper?.appendChild(pill);
    });
  });

  chatForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const prompt = userInput.value.trim();
    if (!prompt) return;

    userInput.value = '';
    appendMessage('user', prompt);

    // Dynamic Telemetry Elements
    const traceVector = document.getElementById('trace-vector');
    const dotVector = document.getElementById('dot-vector');
    const traceWan = document.getElementById('trace-wan');
    const dotWan = document.getElementById('dot-wan');

    // Reset status to active ingestion trace
    const isBroadLegal = prompt.toLowerCase().includes('global') || prompt.toLowerCase().includes('standard') || prompt.toLowerCase().includes('tax') || prompt.toLowerCase().includes('search') || prompt.toLowerCase().includes('web');

    if (isBroadLegal) {
      // Light up Web Agent panel
      traceWan?.classList.remove('bg-[#121418]/40', 'border-[#1c1f26]/40', 'text-slate-500');
      traceWan?.classList.add('bg-[#121418]', 'border-amber-500/30', 'text-amber-400');
      dotWan?.classList.remove('bg-slate-800');
      dotWan?.classList.add('bg-amber-400', 'shadow-[0_0_6px_#amber-400]');
    } else {
      // Light up Vector Agent panel
      traceVector?.classList.remove('bg-[#121418]/40', 'border-[#1c1f26]/40', 'text-slate-500');
      traceVector?.classList.add('bg-[#121418]', 'border-[#84a98c]/30', 'text-[#84a98c]');
      dotVector?.classList.remove('bg-slate-800');
      dotVector?.classList.add('bg-[#84a98c]', 'shadow-[0_0_6px_#84a98c]');
    }

    try {
      const badgeType = isBroadLegal ? 'TRACE // WAN_FALLBACK' : 'TRACE // LCL_VECTOR_ISOLATION';

      const response = await fetch('http://127.0.0.1:8000/api/chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ query: prompt, history: chatHistory })
      });

      const data = await response.json();
      appendMessage('assistant', data.response, badgeType);
      chatHistory.push({ role: 'user', content: prompt }, { role: 'assistant', content: data.response });
    } catch (error) {
      appendMessage('assistant', 'RUNTIME ENGINE FAIL: Verification parameters disconnected.');
    } finally {
      // Gracefully restore tracking blocks to standard standby mode after response arrives
      setTimeout(() => {
        traceVector?.setAttribute('class', 'flex items-center gap-2 px-2.5 py-1 rounded bg-[#121418]/40 border border-[#1c1f26]/40 text-slate-500 transition-all');
        dotVector?.setAttribute('class', 'h-1.5 w-1.5 rounded-full bg-slate-800');
        traceWan?.setAttribute('class', 'flex items-center gap-2 px-2.5 py-1 rounded bg-[#121418]/40 border border-[#1c1f26]/40 text-slate-500 transition-all');
        dotWan?.setAttribute('class', 'h-1.5 w-1.5 rounded-full bg-slate-800');
      }, 1200);
    }
  });

function appendMessage(role: string, content: string, badge?: string) {
    const chatArena = document.getElementById('chat-arena');
    if (!chatArena) return;

    const msgDiv = document.createElement('div');
    msgDiv.className = `border rounded-md p-5 transition-all ${role === 'user' ? 'bg-[#181b22]/40 border-[#1c1f26]' : 'bg-[#0b0c0e]/60 border-[#1c1f26]/60'}`;
    
    const metaRow = document.createElement('div');
    metaRow.className = "flex items-center gap-2 mb-2 font-mono text-[11px]";
    
    const actor = document.createElement('span');
    actor.className = role === 'user' ? 'text-slate-400 font-semibold' : 'text-[#84a98c] font-bold';
    actor.innerText = role === 'user' ? '› USER.CMD' : '› ENGINE.SYS';
    metaRow.appendChild(actor);

    if (badge) {
      const bSpan = document.createElement('span');
      bSpan.className = `px-1.5 py-0.5 rounded text-[10px] font-mono font-bold bg-amber-900/20 text-amber-400 border border-amber-900/30`;
      bSpan.innerText = badge;
      metaRow.appendChild(bSpan);
    }

    const bodyText = document.createElement('p');
    // Bumped class to base (16px) for crisp readability
    bodyText.className = "text-base leading-relaxed tracking-normal font-sans mt-2 whitespace-pre-wrap text-slate-200 selection:bg-[#84a98c]/20";
    bodyText.innerText = content;
    
    msgDiv.appendChild(metaRow);
    msgDiv.appendChild(bodyText);
    chatArena.appendChild(msgDiv);
    chatArena.scrollTop = chatArena.scrollHeight;
  }
</script>