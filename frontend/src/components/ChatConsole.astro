<div id="chat-console" class="bg-[#121418] border border-[#1c1f26] rounded-md flex flex-col h-[600px] shadow-2xl overflow-hidden">
  <div id="pillars-container" class="bg-[#0b0c0e] border-b border-[#1c1f26] px-4 py-3 hidden">
    <span class="text-[9px] uppercase font-bold font-mono tracking-widest text-slate-500 block mb-2">TARGET SUBSURFACE SECTOR INTAKES:</span>
    <div id="pills-wrapper" class="flex flex-wrap gap-1.5"></div>
  </div>

  <div id="chat-arena" class="flex-1 p-5 overflow-y-auto space-y-5 bg-gradient-to-b from-[#0b0c0e]/20 to-transparent text-sm custom-scrollbar">
    <div class="max-w-xl border border-[#1c1f26] bg-[#0b0c0e]/60 rounded-md p-4 text-slate-400 font-mono space-y-1 text-xs">
      <p class="text-slate-200 font-bold">SYSTEM CORE INITIALIZED // INSTANCE RUNNING</p>
      <p class="text-slate-500">Provide a structured contract to isolate RAG segments, or run global lookups directly below.</p>
    </div>
  </div>

  <form id="chat-form" class="border-t border-[#1c1f26] p-4 bg-[#0b0c0e]/50 flex items-center gap-3 shrink-0">
    <input type="text" id="user-input" placeholder="Query contract parameters or assert regulatory thresholds..." autocomplete="off" class="flex-1 bg-[#0b0c0e] border border-[#1c1f26] rounded px-4 py-3.5 text-base text-slate-200 font-mono placeholder-slate-600 focus:outline-none focus:border-[#424b5d] transition-all" />
    <button type="submit" class="bg-[#84a98c] hover:bg-[#9dc1a3] text-slate-950 text-xs font-bold font-mono px-6 py-3.5 rounded transition-all uppercase tracking-widest shadow-md cursor-pointer">
      EXECUTE
    </button>
  </form>
</div>

<style>
  /* Optional polish: Ensure scroll tracks match your clean dark interface values */
  .custom-scrollbar::-webkit-scrollbar {
    width: 6px;
  }
  .custom-scrollbar::-webkit-scrollbar-track {
    background: #0b0c0e;
  }
  .custom-scrollbar::-webkit-scrollbar-thumb {
    background: #1c1f26;
    border-radius: 3px;
  }
  .custom-scrollbar::-webkit-scrollbar-thumb:hover {
    background: #232730;
  }
</style>

<script>
  let chatHistory: Array<{role: string, content: string}> = [];
  
  const chatForm = document.getElementById('chat-form');
  const userInput = document.getElementById('user-input') as HTMLInputElement;
  const pillarsContainer = document.getElementById('pillars-container');
  const pillsWrapper = document.getElementById('pills-wrapper');

  const API_BASE_URL = import.meta.env.PUBLIC_API_URL || 'https://agentic-auditor.onrender.com';

  window.addEventListener('document-processed', (e: any) => {
    if (!pillarsContainer || !pillsWrapper || !userInput) return;
    
    pillarsContainer.classList.remove('hidden');
    pillsWrapper.innerHTML = '';
    
    e.detail.sections.forEach((section: string) => {
      const pill = document.createElement('button');
      pill.className = "px-2.5 py-1 text-[10px] font-mono rounded bg-[#121418] border border-[#1c1f26] text-slate-400 hover:text-slate-200 hover:border-slate-500 transition-colors cursor-pointer";
      pill.innerText = section.toUpperCase();
      pill.onclick = () => {
        userInput.value = `Audit core structures for segment: [${section}] // Target: `;
        userInput.focus();
      };
      pillsWrapper.appendChild(pill);
    });
  });

  chatForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!userInput) return;
    
    const prompt = userInput.value.trim();
    if (!prompt) return;

    userInput.value = '';
    appendUserMessage(prompt);

    const traceVector = document.getElementById('trace-vector');
    const dotVector = document.getElementById('dot-vector');
    const traceWan = document.getElementById('trace-wan');
    const dotWan = document.getElementById('dot-wan');

    let reader: ReadableStreamDefaultReader<Uint8Array> | null = null;

    try {
      const response = await fetch(`${API_BASE_URL.replace(/\/$/, '')}/api/chat`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ query: prompt, history: chatHistory })
      });

      if (response.status === 429) {
        const errorData = await response.json();
        const messageElement = createAssistantPlaceholder();
        const bodyTextEl = messageElement.querySelector('.body-text') as HTMLElement;
        const badgeContainer = messageElement.querySelector('.badge-container') as HTMLElement;

        messageElement.classList.remove('border-[#1c1f26]/60');
        messageElement.classList.add('border-amber-500/20', 'bg-amber-950/10');
        badgeContainer.innerHTML = `<span class="px-1.5 py-0.5 rounded text-[9px] font-mono font-bold bg-amber-950 text-amber-400 border border-amber-400/40">HTTP 429 // ACCESS_DENIED</span>`;
        bodyTextEl.innerText = errorData.message;
        bodyTextEl.classList.remove('text-slate-400', 'animate-pulse');
        bodyTextEl.classList.add('text-amber-200/80');
        return; 
      }

      if (!response.body) throw new Error("No readable stream channel.");
      reader = response.body.getReader();
      const decoder = new TextDecoder();
      
      const messageElement = createAssistantPlaceholder();
      const bodyTextEl = messageElement.querySelector('.body-text') as HTMLElement;
      const badgeContainer = messageElement.querySelector('.badge-container') as HTMLElement;

      let isFirstChunk = true;
      let standardResponseText = "";

      while (true) {
        const { value, done } = await reader.read();
        if (done) break;

        const chunkText = decoder.decode(value);
        const lines = chunkText.split('\n');

        for (const line of lines) {
          if (!line.startsWith('data: ')) continue;
          try {
            const parsed = JSON.parse(line.replace('data: ', ''));
            if (parsed.type === 'metadata') {
              if (parsed.badge.includes('WAN')) {
                traceWan?.setAttribute('class', 'flex items-center gap-2 px-3 py-1.5 rounded bg-[#121418] border border-amber-500/30 text-amber-400 transition-all');
                dotWan?.setAttribute('class', 'h-2 w-2 rounded-full bg-amber-400 shadow-[0_0_6px_#amber-400]');
              } else {
                traceVector?.setAttribute('class', 'flex items-center gap-2 px-3 py-1.5 rounded bg-[#121418] border border-[#84a98c]/30 text-[#84a98c] transition-all');
                dotVector?.setAttribute('class', 'h-2 w-2 rounded-full bg-[#84a98c] shadow-[0_0_6px_#84a98c]');
              }
              badgeContainer.innerHTML = `<span class="px-1.5 py-0.5 rounded text-[9px] font-mono font-bold bg-zinc-800 text-zinc-400 border border-zinc-700/40">${parsed.badge}</span>`;
            } 
            
            if (parsed.type === 'content') {
              if (isFirstChunk) {
                bodyTextEl.innerText = '';
                bodyTextEl.classList.remove('animate-pulse', 'text-slate-400');
                bodyTextEl.classList.add('text-slate-200');
                isFirstChunk = false;
              }
              bodyTextEl.innerText += parsed.token;
              standardResponseText += parsed.token;
              
              const chatArena = document.getElementById('chat-arena');
              if (chatArena) chatArena.scrollTop = chatArena.scrollHeight;
            }
          } catch (e) {}
        }
      }
      
      chatHistory.push({ role: 'user', content: prompt }, { role: 'assistant', content: standardResponseText });
    } catch (error) {
      console.error(error);
    } finally {
      if (reader) {
        reader.releaseLock();
      }
      setTimeout(() => {
        traceVector?.setAttribute('class', 'flex items-center gap-2 px-3 py-1.5 rounded bg-[#121418]/40 border border-[#1c1f26]/40 text-slate-500 transition-all');
        dotVector?.setAttribute('class', 'h-2 w-2 rounded-full bg-slate-800');
        traceWan?.setAttribute('class', 'flex items-center gap-2 px-3 py-1.5 rounded bg-[#121418]/40 border border-[#1c1f26]/40 text-slate-500 transition-all');
        dotWan?.setAttribute('class', 'h-2 w-2 rounded-full bg-slate-800');
      }, 1000);
    }
  });

  function appendUserMessage(text: string) {
    const chatArena = document.getElementById('chat-arena');
    if (!chatArena) return;

    const div = document.createElement('div');
    div.className = 'border rounded-md p-5 bg-[#181b22]/40 border-[#1c1f26] text-slate-200 max-w-full overflow-hidden min-w-0';
    div.innerHTML = `
      <div class="flex items-center gap-2 mb-2 font-mono text-[10px]">
        <span class="text-slate-500 font-semibold">› USER.CMD</span>
      </div>
      <p class="text-sm leading-relaxed tracking-normal font-sans mt-2 text-slate-200 break-words whitespace-pre-wrap min-w-0">${text}</p>
    `;
    chatArena.appendChild(div);
    chatArena.scrollTop = chatArena.scrollHeight;
  }

  function createAssistantPlaceholder() {
    const chatArena = document.getElementById('chat-arena');
    if (!chatArena) return document.createElement('div');

    const div = document.createElement('div');
    div.className = 'border rounded-md p-5 bg-[#0b0c0e]/60 border-[#1c1f26]/60 text-slate-300 max-w-full overflow-hidden min-w-0';
    div.innerHTML = `
      <div class="flex items-center justify-between mb-2 font-mono text-[10px]">
        <div class="flex items-center gap-2">
          <span class="text-[#84a98c] font-bold">› ENGINE.SYS</span>
        </div>
        <div class="badge-container"></div>
      </div>
      <p class="body-text text-sm leading-relaxed tracking-normal font-sans mt-2 text-slate-400 animate-pulse break-words whitespace-pre-wrap min-w-0"></p>
    `;
    chatArena.appendChild(div);
    chatArena.scrollTop = chatArena.scrollHeight;
    return div;
  }
</script>