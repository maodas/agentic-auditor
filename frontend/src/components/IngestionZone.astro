---
---
<div class="space-y-4">
  <div id="drop-zone" class="border border-dashed border-[#232730] hover:border-[#3a4150] rounded-md p-6 text-center cursor-pointer transition-all bg-[#121418]/40 group">
    <input type="file" id="file-input" accept=".pdf" class="hidden" />
    <div class="space-y-1.5">
      <p class="text-sm font-semibold text-slate-300 group-hover:text-[#e0a96d] font-mono tracking-wide transition-colors">EXECUTE PAYLOAD ATTACHMENT (.PDF)</p>
      <p class="text-xs text-slate-500 font-mono tracking-tight">RAW CONTRACT CONTEXT COMPARTMENTALIZATION ACTIVE</p>
    </div>
  </div>

  <div id="upload-status" class="hidden border border-[#1c1f26] bg-[#0b0c0e] rounded-md p-4 space-y-2.5 font-mono text-xs">
    <div class="flex items-center justify-between">
      <span id="status-text" class="text-[#84a98c] font-bold tracking-wider">PIPELINE_STAGED</span>
      <span id="filename-badge" class="text-slate-500 max-w-[200px] truncate"></span>
    </div>
    <div class="w-full bg-[#1c1f26] h-[2px] overflow-hidden rounded-full">
      <div id="progress-bar" class="bg-[#84a98c] h-[2px] rounded-full transition-all duration-300 w-1/12"></div>
    </div>
    <div id="pipeline-logs" class="space-y-1 text-slate-500 max-h-32 overflow-y-auto pt-1 border-t border-[#1c1f26]"></div>
  </div>
</div>

<script>
  const dropZone = document.getElementById('drop-zone');
  const fileInput = document.getElementById('file-input') as HTMLInputElement;
  const uploadStatus = document.getElementById('upload-status');
  const progressBar = document.getElementById('progress-bar');
  const statusText = document.getElementById('status-text');
  const filenameBadge = document.getElementById('filename-badge');
  const pipelineLogs = document.getElementById('pipeline-logs');

  const API_BASE_URL = import.meta.env.PUBLIC_API_URL || 'https://agentic-auditor.onrender.com';

  function logStep(message: string, isError = false) {
    const line = document.createElement('div');
    line.className = isError ? 'text-rose-500 font-bold' : 'text-slate-500';
    line.innerText = `[log] ${message}`;
    pipelineLogs?.appendChild(line);
    pipelineLogs!.scrollTop = pipelineLogs!.scrollHeight;
  }

  dropZone?.addEventListener('click', () => fileInput?.click());
  dropZone?.addEventListener('dragover', (e) => { e.preventDefault(); dropZone.classList.add('border-slate-500', 'bg-[#121418]'); });
  dropZone?.addEventListener('dragleave', () => { dropZone.classList.remove('border-slate-500', 'bg-[#121418]'); });
  dropZone?.addEventListener('drop', (e) => {
    e.preventDefault();
    dropZone.classList.remove('border-slate-500', 'bg-[#121418]');
    if (e.dataTransfer?.files?.length) handleUpload(e.dataTransfer.files[0]);
  });
  fileInput?.addEventListener('change', () => { if (fileInput.files?.length) handleUpload(fileInput.files[0]); });

  async function handleUpload(file: File) {
    if (!file.name.endsWith('.pdf')) { 
      alert('Target payload must be a valid PDF format.');
      return; 
    }
    uploadStatus?.classList.remove('hidden');
    filenameBadge!.innerText = file.name.toUpperCase();
    pipelineLogs!.innerHTML = '';
    
    progressBar!.style.width = '25%';
    logStep('Initializing runtime thread isolation...');
    const formData = new FormData();
    formData.append('file', file);

    try {
      progressBar!.style.width = '60%';
      logStep('Analyzing logical section indices...');
      
      const response = await fetch(`${API_BASE_URL.replace(/\/$/, '')}/api/upload`, { method: 'POST', body: formData });
      if (!response.ok) {
        const errorData = await response.json();
        throw new Error(errorData.detail || 'Ingestion pipeline structural failure.');
      }
      
      const data = await response.json();
      progressBar!.style.width = '100%';
      statusText!.innerText = 'TARGETS_RESOLVED';
      statusText!.className = 'text-[#84a98c] font-bold';
      logStep(`Context namespaces mapped: ${data.detected_sections.join(', ')}`);
      window.dispatchEvent(new CustomEvent('document-processed', { detail: { sections: data.detected_sections } }));
    } catch (error: any) {
      progressBar!.style.width = '100%';
      progressBar!.classList.add('bg-rose-950');
      statusText!.innerText = 'INVALID_PAYLOAD';
      statusText!.className = 'text-rose-500 font-bold';
      logStep(`${error.message}`, true);
      logStep('Terminating document parsing context loops.', true);
    }
  }
</script>