---
import '../styles/global.css';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en" class="bg-slate-950 text-slate-100 selection:bg-indigo-500/30">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Agentic Legal Auditor Showcase" />
		<meta name="viewport" content="width=device-width" />
		
		<link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><rect width=%22100%22 height=%22100%22 rx=%2220%22 fill=%22%230b0c0e%22/><text y=%2265%22 x=%2215%22 font-family=%22monospace%22 font-size=%2255%22 font-weight=%22bold%22 fill=%22%2384a98c%22>&gt;_</text></svg>" />
		
		<title>{title}</title>
	</head>
	<body class="min-h-screen font-sans antialiased bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-slate-900 via-slate-950 to-black">
		<slot />
	</body>
</html>